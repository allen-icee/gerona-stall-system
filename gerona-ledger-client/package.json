{
    "name": "gerona-ledger-client",
    "version": "1.0.0",
    "description": "Client wrapper for the Gerona Stall Ledger System",
    "author": "Allen",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "dist": "electron-builder"
    },
    "dependencies": {
        "electron": "^43.0.0"
    },
    "devDependencies": {
        "electron-builder": "^26.15.3"
    },
    "build": {
        "appId": "com.gerona.ledgerclient",
        "productName": "Gerona Ledger Client",
        "directories": {
            "output": "dist"
        },
        "win": {
            "target": [
                "nsis",
                "portable"
            ],
            "icon": "MunicipalityLogo.png"
        }
    }
}
